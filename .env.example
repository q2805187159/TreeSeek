# TreeSeek environment template
# ------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need.
#
# Minimum required fields for live model calls:
#   MODEL
#   API_KEY
#   API_URL
#
# Example:
#   MODEL=Pro/deepseek-ai/DeepSeek-V3.2
#   API_KEY=sk-xxxx
#   API_URL=https://api.siliconflow.cn/v1

# ------------------------------------------------------------
# Model provider settings
# ------------------------------------------------------------

# Model ID used by TreeSeek.
# If you use an OpenAI-compatible base URL, TreeSeek will normalize the model
# name when needed, so you usually do not need to manually prepend `openai/`.
MODEL=Pro/deepseek-ai/DeepSeek-V3.2

# Provider API key.
API_KEY=

# Provider base URL.
API_URL=

# Optional OpenAI-compatible aliases.
# You normally do not need to set these if API_KEY / API_URL are already set.
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_BASE_URL=

# ------------------------------------------------------------
# TreeSeek runtime controls
# ------------------------------------------------------------

# Maximum concurrent LLM requests issued by TreeSeek itself.
# Keep this below your provider's hard organization concurrency limit.
TREESEEK_LLM_MAX_CONCURRENCY=2

# Maximum requests per rolling minute that TreeSeek should allow itself to use.
# Keep this below the official provider RPM limit to leave safety margin.
TREESEEK_LLM_MAX_RPM=12

# Base retry delay in seconds for temporary model/provider failures.
TREESEEK_LLM_RETRY_BASE_DELAY=1.0

# Maximum retry delay in seconds for exponential backoff.
TREESEEK_LLM_RETRY_MAX_DELAY=8.0

# Enable detailed runtime debug logs.
# Default recommended value is `no`.
# Set to `yes` only when debugging TOC parsing, recursive split, or provider issues.
TREESEEK_DEBUG_LOGS=no

# ------------------------------------------------------------
# LiteLLM logging worker tuning
# ------------------------------------------------------------

# Maximum allowed time for a single LiteLLM background logging coroutine.
LOGGING_WORKER_MAX_TIME_PER_COROUTINE=120

# Maximum total time spent clearing the LiteLLM logging queue before exit.
MAX_TIME_TO_CLEAR_QUEUE=15
